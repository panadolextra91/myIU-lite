# scripts/check.env.example — template. Copy to scripts/check.env (gitignored) to let
# the pre-push gate (scripts/check.sh) run `go test` automatically without re-exporting
# DATABASE_URL each shell.
#
#   cp scripts/check.env.example scripts/check.env
#
# Use a DEDICATED test DB (NOT your dev DB) — the suite mutates data and briefly renames
# the notifications table. One-time setup with Docker Postgres running:
#   docker exec myiu-lite-postgres-1 psql -U myiu -d myiu_dev -c "CREATE DATABASE myiu_test;"
#   migrate -path backend/db/migrations -database "postgres://myiu:myiu@localhost:5432/myiu_test?sslmode=disable" up
#
# `:=` means an explicit DATABASE_URL already set in your shell still wins.
: "${DATABASE_URL:=postgres://myiu:myiu@localhost:5432/myiu_test?sslmode=disable}"
export DATABASE_URL
